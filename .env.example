DATABASE_URL="postgresql://teg:teg@localhost:5432/teg_saas?schema=public"

# Session/JWT secret for auth (login/password + PIN). Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"

# Super Admin account (npm run admin:seed / admin:reset-password), docs/spec/06-super-admin.md
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="replace-with-a-strong-password"

# Secret expected in the X-FluentCart-Webhook-Secret header, docs/spec/06-super-admin.md п.5
FLUENTCART_WEBHOOK_SECRET="replace-with-a-random-secret"

# Optional fallbacks — normally set via /admin/settings (SystemSettings), kept here
# only so environments without that DB row configured yet still work.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
