# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example

# dev-server logs from local test runs
dev-server.log

# Claude Code local session/tool state — not shared project config
.claude/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# user-uploaded files (asset photos, operator avatars) — local disk per tenant
/public/uploads

# vendor reference source dropped in for integration research —
# not part of this project, not committed
/temp apps/
/FluentCart/
/Progressify/
