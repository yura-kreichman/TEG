# Копируется в .env на сервере (рядом с docker-compose.prod.yml), не коммитится.
# DATABASE_URL для приложения собирается docker-compose'ом автоматически из
# POSTGRES_PASSWORD (см. docker-compose.prod.yml) — здесь его задавать не нужно.

POSTGRES_PASSWORD="replace-with-a-strong-random-password"

# UID/GID владельца папки домена на хосте (см. `id <site-user>`, в
# ISPmanager это пользователь сайта, например md33) — public/uploads это
# bind-mount на папку домена, не именованный Docker-volume, поэтому
# контейнер должен писать под тем же UID/GID, что владеет папкой на хосте.
SITE_UID="1000"
SITE_GID="1000"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"

# Секрет вебхуков FluentCart (docs/spec/06-super-admin.md, п.5) — тот же
# заголовок X-FluentCart-Webhook-Secret настраивается в фидах интеграции.
FLUENTCART_WEBHOOK_SECRET="replace-with-a-random-secret"

# Telegram-бот для сводок (Настройки -> Сводки). Оставьте пустыми, если модуль не используется.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""

# SMTP для email-сводок и восстановления пароля. Оставьте пустыми, если не используется.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Web Push (push-уведомления владельцу о сводках при установленном PWA).
# Сгенерировать один раз: npx web-push generate-vapid-keys — и больше не
# менять: смена пары ключей аннулирует все существующие подписки браузеров,
# владельцам придётся заново включать push в настройках.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# Лендинг (docs/spec/08-landing.md). Соль обязательна — генерировать так же,
# openssl rand -base64 32, СВОЙ секрет для прода, не тот же, что в dev .env.
LANDING_STATS_SALT="replace-with-a-random-secret"
# Публичный адрес приложения — для canonical/OG-ссылок Лендинга.
SITE_URL="https://my.rentos365.app"
