// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ЯДРО: тенанты, подписки, пакеты, модули
// ============================================================================

enum SubscriptionStatus {
  active
  paused // сезонная пауза, инициирует Owner
  suspended // Super Admin ставит вручную через /admin/tenants — проблемы с оплатой и т.п. Отдельного объекта-оверрайда нет (убран по фидбеку 2026-07-11) — статус выставляется напрямую и остаётся, пока его не сменит следующий вебхук FluentCart или сам админ.
  expired
}

// Пакет подписки — лимиты + цена (docs/spec/00-architecture.md). Модули
// больше не различаются по пакетам — во всех пакетах доступны все модули,
// разница только в числовых лимитах (фидбек пользователя 2026-07-12).
model Package {
  id                  String   @id @default(cuid())
  name                String
  maxPoints           Int
  maxZones            Int
  maxAssets           Int
  maxOperators        Int
  priceMonthly        Decimal  @db.Decimal(10, 2)
  // Привязка к продукту FluentCart (docs/spec/06-super-admin.md) — вебхук
  // ищет Package по этому полю, чтобы понять, на какой план переключить
  // тенанта. Не источник истины по цене (это priceMonthly) — просто ключ
  // сопоставления с биллингом.
  fluentcartProductId String?  @unique
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenants Tenant[]
}

model Tenant {
  id                    String             @id @default(cuid())
  name                  String
  // Человекочитаемый идентификатор, используемый в публичных ссылках двух
  // модулей: Инструктажи (/i/{tenant-slug}/{instruction-slug}, docs/spec/
  // 07-instructions.md) и Лендинг (/s/{tenant-slug}, docs/spec/
  // 08-landing.md). Генерируется из name при регистрации (транслитерация +
  // kebab-case, коллизии — числовой суффикс). РЕДАКТИРУЕМ владельцем
  // (решение 2026-07-13 — отменяет более раннее "неизменяем публично" из
  // 07-instructions.md) через раздел Лендинг; старое значение при смене
  // уходит в TenantOldSlug для 301, который отрабатывает оба публичных
  // роута. Nullable до бэкфилла существующих тенантов, затем NOT NULL.
  slug                  String?            @unique
  // Логотип на главной владельца и в отчётах — путь в /uploads/<tenantId>/...,
  // как Asset.photoUrl/Operator.avatarUrl (см. src/lib/uploads.ts).
  logoUrl               String?
  packageId             String
  package               Package            @relation(fields: [packageId], references: [id])
  subscriptionStatus    SubscriptionStatus @default(active)
  // До интеграции с FluentCart (docs/spec/06-super-admin.md) управлялось
  // вручную из админ-модуля. Планировщик (summary-scheduler.ts) раз в минуту
  // переводит active в expired, когда дата прошла — актуально и сейчас как
  // предохранитель независимо от вебхуков. Триала как отдельного статуса нет
  // (фидбек пользователя 2026-07-11) — ограниченный бесплатный доступ даёт
  // Free-пакет (Package с priceMonthly=0), а не time-boxed период.
  subscriptionExpiresAt DateTime?

  // Интеграция с FluentCart (docs/spec/06-super-admin.md) — вебхук находит
  // тенанта по этому полю (создаёт нового, если ещё не было).
  fluentcartCustomerId String?   @unique
  // order.id заказа, который последним перевёл тенанта в active (см.
  // syncTenantFromFluentCartEvent). Нужен, чтобы отличать "истекающее"
  // событие от ТЕКУЩЕГО заказа/подписки от такого же события у старого,
  // уже неактуального заказа того же клиента (например, удалили/отменили
  // дублирующий тестовый заказ) — без этого поля любое "истекающее" событие
  // от любого чужого заказа клиента слепо переводило тенанта в expired,
  // даже если реальная активная подписка осталась (найдено 2026-07-12).
  fluentcartOrderId    String?
  // Чисто информационное "действует до" из subscriptions[].next_billing_date
  // вебхука FluentCart (docs/fluentcart-webhook-schema.md §3) — FluentCart не
  // отдаёт отдельного "access end date" поля, только дату следующего
  // списания. НЕ источник правды для логики доступа (это subscriptionStatus)
  // — только для отображения в кабинете владельца. Отдельно от
  // subscriptionExpiresAt (тот — ручной/плановый жёсткий срок, выставляется
  // Super Admin'ом напрямую или планировщиком, самостоятельный механизм).
  currentPeriodEnd     DateTime?
  // Точечный оверрайд числовых лимитов пакета для конкретного тенанта —
  // { maxPoints?, maxZones?, maxAssets?, maxOperators? } | null, поверх
  // package.*. См. getTenantLimits() в src/lib/packages.ts.
  limitOverrides       Json?
  // Ручной оверрайд Super Admin'ом (запрос пользователя 2026-07-17: "опция
  // установить владельцу пакет Unlimited без ограничений, которого нет в
  // пакетах") — снимает ВСЕ 4 лимита разом, полностью байпасит и package.*,
  // и limitOverrides (getTenantLimits проверяет unlimited раньше обоих).
  // Отдельное поле, а не строка в списке Package: намеренно НЕ покупаемый,
  // не создаваемый через FluentCart пакет — только ручной рубильник в
  // /admin/tenants/[id], как limitOverrides.
  unlimited            Boolean   @default(false)

  // Контакты тенанта для платформенной поддержки — заполняет Super Admin в
  // админ-модуле, не сам владелец (докс 2026-07-10, "полные настройки
  // тенанта"). contactPhone — телефон, отдельный от email логина владельца
  // (User.email). adminNote — внутренняя заметка, владельцу никогда не видна.
  contactPhone String?
  adminNote    String?

  // Мультиязычность (настройка тенанта, см. 00-architecture.md). Тема
  // светлая/тёмная больше не тенантная настройка (убрано по фидбеку
  // пользователя 2026-07-09) — только личный выбор каждого устройства
  // (next-themes localStorage), см. src/app/layout.tsx/operator/layout.tsx.
  locale       String @default("ru")
  accentScheme String @default("green")

  // Фон приложения (docs/spec/03-design-system.md, "Фон приложения") —
  // только кабинет владельца, тот же оптимистичный save-механизм, что у
  // accentScheme выше. "none" = "Без фона" (текущее поведение), тот же
  // приём default-значения, что у accentScheme.
  bgStyle String @default("none")

  // Валюта — чисто визуальная настройка (docs/spec/03-design-system.md,
  // "Числа и деньги" → "Валюта"): суперскрипт-знак у денежных сумм.
  // null = "не указана" (по умолчанию, спека) — сумма выводится без знака,
  // не "RUB" или что-то ещё. Хранится 3-буквенный код из курируемого
  // справочника (src/lib/currency.ts), свободный ввод запрещён — валидация
  // на уровне API, не БД (нет смысла заводить отдельную таблицу/enum ради
  // ~16 фиксированных вариантов).
  currency String?

  // Часовой пояс тенанта (IANA, напр. "Europe/Moscow") — общий для владельца
  // и всех его операторов, задаёт только владелец в "Язык и Регион" (фидбек
  // пользователя 2026-07-11). По умолчанию "UTC" — сохраняет текущее
  // поведение до тех пор, пока владелец явно не выберет свой пояс: расчёт
  // бизнес-дня/планировщик сводок и т.п. пока считают в UTC (докстрока в
  // src/lib/business-day.ts) — это поле только хранит выбор, реальная
  // перепривязка всей день-математики на него — отдельная задача.
  timezone String @default("UTC")

  // "HH:MM" — во сколько обычно начинается смена, подставляется по умолчанию
  // в форму "Добавить смену" оператора (было зашито как 10:00, стало
  // настройкой владельца по фидбеку пользователя 2026-07-10).
  defaultShiftStartTime String @default("10:00")

  // Граница бизнес-дня (docs/spec/05-work-time.md) — перенесено с
  // DailyCashSummarySettings 2026-07-11: значение общетенантное, читает и
  // "Касса за день" (границы бизнес-дня для сдач), и Рабочее время (досдача
  // аванса/премии). Редактируется только в Настройках Рабочего времени
  // (фидбек пользователя 2026-07-11 — раньше дублировалось на экране "Касса
  // за день", убрано оттуда во избежание рассинхрона).
  businessDayBoundary String @default("06:00")

  // Допуск начала смены относительно defaultShiftStartTime (docs/spec/
  // 05-work-time.md, "РЕЖИМ УЧЁТА ВРЕМЕНИ") — ЕДИНЫЙ для обоих режимов
  // учёта времени (было раздельно на auto/manual, объединено по фидбеку
  // пользователя 2026-07-11: один и тот же смысл "когда операторы обычно
  // начинают", не должен настраиваться дважды). Авто: жёсткий запрет —
  // кнопка "Начать смену" недоступна вне окна [по умолчанию−Early;
  // по умолчанию+Late]. Ручной: тот же диапазон ограничивает выбор в
  // колесе "Пришёл" формы "Добавить смену", т.к. в ручном режиме нет живой
  // кнопки для блокировки.
  earlyToleranceMinutes Int @default(120)
  lateToleranceMinutes  Int @default(120)

  // Настройки → Система (запрос пользователя 2026-07-20) — глобальный
  // тумблер Владельца: разрешена ли клиентам оплата Товаров балансом
  // абонемента (docs/spec/09-goods.md, "Продажа" — до этого поля баланс был
  // безусловным способом оплаты наравне с наличными/безналом). default true —
  // у существующих тенантов поведение не меняется молча, только у тех, кто
  // явно выключит. Серверная проверка в /api/operator/goods/sale, не только
  // скрытие кнопки в UI — тот же принцип, что у Operator.goodsAccess.
  goodsAllowBalancePayment Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                         User[]
  operators                     Operator[]
  points                        Point[]
  moneyOps                      MoneyOperation[]
  expenseCategories             ExpenseCategory[]
  abonements                    Abonement[]
  abonementWallets              AbonementWallet[]
  operatorRates                 OperatorRate[]
  shifts                        Shift[]
  balanceCarryovers             OperatorBalanceCarryover[]
  summaryChannels               TenantSummaryChannel[]
  telegramBindCodes             TelegramBindCode[]
  zoneSummarySettings           ZoneSummarySettings?
  dailyCashSummarySettings      DailyCashSummarySettings?
  shiftCloseSummarySettings     ShiftCloseSummarySettings?
  instructionAckSummarySettings InstructionAckSummarySettings?
  dailyCashSummaryDeliveries    DailyCashSummaryDelivery[]
  tasks                         Task[]
  pushSubscriptions             PushSubscription[]
  pushNotificationSettings      PushNotificationSettings?
  instructions                  Instruction[]
  landing                       Landing?
  oldSlugs                      TenantOldSlug[]
  goodsCategories               GoodsCategory[]
  goods                         Goods[]
  goodsSales                    GoodsSale[]
  goodsRevisions                GoodsRevision[]
  goodsReconciliations          GoodsReconciliation[]
}

// ============================================================================
// ЛЮДИ: Owner / Super Admin (обычный аккаунт) и Operator (только PIN)
// ============================================================================

enum UserRole {
  super_admin
  owner
}

// Owner и Super Admin — полноценные аккаунты с email+паролем.
// Super Admin платформенный, tenantId = null. Owner всегда привязан к тенанту.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole

  // Вход Super Admin — логин, НЕ email (docs/spec/06-super-admin.md, п.1:
  // "форма логина: логин + пароль (НЕ email)"). Owner всегда null — Owner
  // входит по email, это поле не для него. email у Super Admin всё равно
  // заполняется (плейсхолдер) при сидировании — колонка на всю таблицу
  // NOT NULL, разводить её отдельно ради одной роли не стали.
  login String? @unique

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Личное переопределение языка тенанта (см. 00-architecture.md); null = язык тенанта.
  locale String?

  // Личный PIN — удобство входа с личного устройства (не путать с Operator PIN).
  pinHash           String?
  failedPinAttempts Int       @default(0)
  pinLockedUntil    DateTime?

  resetTokenHash      String?   @unique
  resetTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdOperators      Operator[]                 @relation("OperatorCreatedBy")
  corrections           CorrectionLog[]
  moneyOps              MoneyOperation[]
  balanceCarryovers     OperatorBalanceCarryover[]
  createdTasks          Task[]                     @relation("TaskCreatedBy")
  assignedTasks         Task[]                     @relation("TaskAssignedUsers")
  pushSubscriptions     PushSubscription[]
  abonementTransactions AbonementTransaction[]
  goodsRestocks         GoodsRestock[]
  goodsSales            GoodsSale[]
  goodsRevisions        GoodsRevision[]
  goodsReconciliations  GoodsReconciliation[]
}

// Одна запись на браузер/устройство, подписавшееся на Web Push (фидбек
// пользователя 2026-07-12: "включи Push-уведомления для Владельца если
// установлено PWA"). endpoint уникален — тот же браузер/устройство при
// повторной подписке (например, после переустановки PWA) обновляет свою же
// строку, а не плодит дубликаты. userId — Owner, подписка живёт в конкретном
// браузере конкретного залогиненного User, один Owner может подписать
// несколько своих устройств. operatorId — то же самое для Оператора
// (добавлено 2026-07-14 для пуш-уведомлений о новых Задачах): ровно одно из
// userId/operatorId заполнено, второе null — проверяется в коде роутов
// подписки, не на уровне БД (как и остальные взаимоисключающие пары полей
// в проекте, см. Asset.photoUrl/iconKey).
model PushSubscription {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  operatorId String?
  operator   Operator? @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  endpoint String @unique
  p256dh   String
  auth     String

  createdAt DateTime @default(now())
}

// Какие типы сводок дублируются Push-уведомлением на устройство(а) Owner'а
// (докс: фидбек пользователя 2026-07-12) — отдельная настройка от
// ZoneSummarySettings/DailyCashSummarySettings/ShiftCloseSummarySettings.enabled
// (те решают, отправлять ли сводку вообще — по Telegram/email); здесь только
// "также продублировать push-уведомлением, если есть хоть одна активная
// подписка". Одна запись на тенанта, а не одна на каждый из трёх типов
// сводок — проще для одного экрана настроек, три отдельные миграции ради
// этого не оправданы.
model PushNotificationSettings {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  zoneSummary       Boolean @default(true)
  dailyCashSummary  Boolean @default(true)
  shiftCloseSummary Boolean @default(true)
  // Начало смены (Авто-режим учёта времени) и подписание Инструктажа —
  // раньше инструктаж слался push'ем безусловно, начало смены не слалось
  // вовсе (запрос пользователя 2026-07-16: "Владелец должен получать Push
  // когда сотрудник начал работать... вдруг Владелец не хочет получать
  // такие уведомления" — оба теперь тумблеры, как остальные три).
  shiftCheckin      Boolean @default(true)
  instructionAck    Boolean @default(true)
  // Инкассация оператором — зонная и общая (запрос пользователя 2026-07-17:
  // "владелец должен получать push об инкассации"), тот же принцип, что
  // shiftCheckin — короткое мгновенное уведомление, не сводка.
  collection        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Operator — создаётся и правится только Owner'ом. Нет email/пароля.
// PIN уникален в рамках тенанта (проверяется bcrypt-перебором при входе —
// до ~50 операторов на тенанта, см. решение в чате аудита).
model Operator {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  pinHash   String
  // Открытым текстом рядом с хешем — чтобы Владелец мог посмотреть ПИН
  // оператора повторно (запрос 2026-07-14), не только задать его через сброс.
  // Не секрет для Владельца по конструкции: PIN назначает и меняет только
  // он сам (00-architecture.md), это код точки/устройства, а не пароль
  // аккаунта — вход всё равно проверяется по pinHash, это поле только для
  // отображения в кабинете Владельца.
  pin       String?
  active    Boolean @default(true)
  // Загруженное фото — как Asset.photoUrl. iconKey — аватар из личной
  // коллекции (public/icon-library/avatars/), запасной вариант, если фото не
  // загружено (тот же приём, что Asset.iconKey — см. icon-picker.tsx).
  avatarUrl String?
  iconKey   String?

  // Личный выбор языка (найдено 2026-07-10: без этого поля язык, выбранный
  // на экране входа оператора, слетал сразу после входа — resolveLocale()
  // падал обратно на язык тенанта, а сменить его сам оператор не мог).
  // null = язык тенанта, как раньше.
  locale String?

  // Доступ к зонам: все (по умолчанию) или выборочно через allowedZones.
  allZonesAccess Boolean @default(true)
  allowedZones   Zone[]  @relation("OperatorAllowedZones")

  // Тумблер модуля "Товары" (docs/spec/09-goods.md, "Доступ") — первый в
  // проекте булев тумблер уровня "весь модуль" у оператора, не список зон,
  // как allZonesAccess/allowedZones выше. Без него оператор не видит раздел
  // продаж, не может продавать и не может сдавать кассу Товаров — владелец
  // всегда может всё это независимо от этого поля.
  goodsAccess Boolean @default(false)

  // Отдельный тумблер РЕВИЗИИ остатков (запрос пользователя 2026-07-19,
  // "Сотрудник не должен иметь право делать ревизию остатков") — намеренно
  // ОТДЕЛЬНЫЙ от goodsAccess: продажа и сдача кассы — обычная работа на
  // точке каждый день, ревизия — действие, которое переопределяет базовую
  // точку для всех будущих расчётов остатка, доверить его можно не любому
  // сотруднику. @default(true) — чтобы уже настроенные операторы не
  // потеряли возможность при накатке миграции, владелец выключает выборочно.
  // Имеет смысл только вместе с goodsAccess=true (без него раздел "Товары"
  // не открыть вовсе).
  revisionAccess Boolean @default(true)

  createdByUserId String
  createdBy       User   @relation("OperatorCreatedBy", fields: [createdByUserId], references: [id])

  // Цветовая метка оператора (docs/spec/05-work-time.md) — как Asset.colorTag,
  // атрибут карточки сотрудника, используется в табеле/сводках/отчётах.
  colorTag String?

  // Режим учёта рабочего времени (docs/spec/05-work-time.md, "РЕЖИМ УЧЁТА
  // ВРЕМЕНИ") — задаёт владелец в экране "Настройки оператора": "manual" —
  // ввод времени вручную (см. "СМЕНА"), "auto" — кнопки Начать/Закончить
  // смену на главном экране PWA. См. isTimeTrackingMode в src/lib/work-time.ts.
  timeTrackingMode String @default("manual")

  // Можно ли уводить баланс ЭТОГО оператора в минус авансом сверх доступного
  // (docs/spec/05-work-time.md, "АВАНС") — персональная настройка, задаёт
  // владелец в "Настройки оператора" (было тенантной 2026-07-11, разделено
  // по фидбеку пользователя: у давно работающего оператора овердрафт может
  // быть разрешён, у новичка — нет, решает владелец per-operator).
  overdraftAllowed Boolean @default(false)

  // Персональное исключение из общего "Допуска начала смены" (тенантного
  // окна вокруг defaultShiftStartTime) — запрос пользователя 2026-07-14:
  // одно общее окно не может обслуживать одновременно "дневного" оператора
  // и, например, студента, который выходит на пару часов вечером. Простой
  // флаг "не проверять вообще", не отдельный кастомный график на оператора —
  // расширять до полноценного персонального окна не было реальной нужды,
  // единственный названный сценарий — "разный график", не "другое, но тоже
  // фиксированное окно".
  skipShiftStartWindow Boolean @default(false)

  // Ручной порядок отображения внутри тенанта (кнопки вверх/вниз в списке
  // операторов) — задаёт владелец, влияет на порядок везде: список
  // операторов, отчёты, сводки (фидбек пользователя 2026-07-11). Новый
  // оператор получает следующий по счёту номер (не 0), чтобы не лезть в
  // начало списка перед существующими.
  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resultsSubmissions    ResultsSubmission[]
  moneyOps              MoneyOperation[]
  // Получатель аванса/премии — отдельно от "кто провёл" (moneyOps выше).
  receivedMoneyOps      MoneyOperation[]           @relation("MoneyOperationBeneficiary")
  rateHistory           OperatorRate[]
  shifts                Shift[]
  balanceCarryovers     OperatorBalanceCarryover[]
  assignedTasks         Task[]                     @relation("TaskAssignedOperators")
  pushSubscriptions     PushSubscription[]
  // Игровая комната (docs/spec/04-game-room.md) — старт/стоп пусков.
  launchesStarted       Launch[]                   @relation("LaunchStartedBy")
  launchesEnded         Launch[]                   @relation("LaunchEndedBy")
  abonementTransactions AbonementTransaction[]
  goodsSales            GoodsSale[]
  goodsRevisions        GoodsRevision[]
  goodsReconciliations  GoodsReconciliation[]
}

// ============================================================================
// СЧЁТЧИКИ: точки → зоны → активы → тарифы (см. 01-counters.md)
// ============================================================================

model Point {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name    String
  // Уже существовало; теперь также используется Лендингом (docs/spec/
  // 08-landing.md). Найденный пробел (докс, "Открытые вопросы"): сейчас
  // редактируется только в форме создания точки, кебаб-меню правки нет —
  // добавляется на Шаге 5 вместе с новыми полями ниже.
  address String?
  iconKey String? // ключ иконки lucide (см. src/components/icon-picker.tsx)

  // Поля docs/spec/08-landing.md, секция "Где нас найти" — все новые. city
  // нужен для SEO (город должен быть в видимом тексте страницы, не только в
  // мета), координаты — для JSON-LD geo (schema.org требует именно числа,
  // ссылку туда не подставить). hoursNote — свободная текстовая приписка к
  // часам ("в дождь не работаем"), не структурная.
  city      String?
  latitude  Float?
  longitude Float?
  hoursNote String?
  // Готовая ссылка на карту (Google Maps, в т.ч. короткие вида
  // maps.app.goo.gl/..., или Яндекс.Карты) — решение пользователя
  // 2026-07-13: координаты не всегда ведут в точное место (может быть уже
  // существующая метка заведения на карте с отзывами/фото), поэтому кнопка
  // "Открыть в картах" использует ЭТУ ссылку напрямую, если она задана, и
  // только при её отсутствии — синтезированную из latitude/longitude.
  // Публичная страница НЕ резолвит короткую ссылку сама (докс: ноль внешних
  // запросов) — просто <a href>, переход делает браузer посетителя.
  mapsUrl   String?

  // Временная деактивация (докс: сезонность — решение пользователя
  // 2026-07-13, "может быть связано с сезонным фактором работы точки"), тот
  // же паттерн, что Zone.active (src/app/api/operator/submission-context) —
  // Точка скрыта с Лендинга (карточка "Где нас найти", "Прокат" её зон,
  // "Наш парк" её активов, "Сегодня работают") и из ростер-переключателя
  // точки у роуминг-устройств оператора, но НЕ блокирует уже привязанное
  // "домашнее" устройство точки — это отдельная, более рискованная гейтинг-
  // задача, не запрошенная явно.
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zones                      Zone[]
  devices                    PointDevice[]
  resultsSubmissions         ResultsSubmission[]
  // Операции advance/bonus_payout (docs/spec/05-work-time.md) — касса точки в
  // целом, не привязанная ни к одной конкретной зоне. См. MoneyOperation.pointId.
  moneyOps                   MoneyOperation[]
  shifts                     Shift[]
  summaryChannels            TenantSummaryChannel[]
  dailyCashSummaryDeliveries DailyCashSummaryDelivery[]
  tasks                      Task[]
  openingHours               PointOpeningHours[]
  abonementTransactions      AbonementTransaction[]
  goodsStocks                GoodsStock[]
  goodsRestocks              GoodsRestock[]
  goodsSales                 GoodsSale[]
  goodsRevisions             GoodsRevision[]
  goodsReconciliations       GoodsReconciliation[]
}

// Часы работы точки, по одной строке на день недели (docs/spec/08-landing.md,
// "Где нас найти") — не одно текстовое поле: нужно и для расчёта "сейчас
// открыто/закрыто" (сравнение локального времени тенанта с opensAt/closesAt
// конкретного weekday), и для JSON-LD openingHoursSpecification (schema.org
// ждёт ровно такую форму: dayOfWeek + opens + closes на объект).
// weekday: 0=понедельник..6=воскресенье — НЕ JS Date.getDay() (там
// 0=воскресенье), конвертация явная в коде, не полагаемся на совпадение.
// Отсутствие ВСЕХ 7 строк для точки = "часы не заполнены" (докс: "если
// данных недостаточно — строка не рендерится") — форма настроек Точки
// всегда сохраняет все 7 сразу, частичного набора не бывает. isOpen=false
// (opensAt/closesAt null) = точка в этот день не работает; условие
// проверяется в коде, не CHECK-констрейнтом, как и остальные подобные поля
// в этой схеме. Оверночные интервалы (закрытие после полуночи) не
// поддерживаются в MVP — closesAt позже opensAt в пределах одного дня,
// для детского проката это ограничение принято.
model PointOpeningHours {
  id      String @id @default(cuid())
  pointId String
  point   Point  @relation(fields: [pointId], references: [id], onDelete: Cascade)

  weekday  Int
  isOpen   Boolean @default(false)
  opensAt  String? // "HH:MM"
  closesAt String? // "HH:MM"

  @@unique([pointId, weekday])
}

// Устройство точки: активируется владельцем или через установочный QR/ссылку —
// одна активация = одна привязка PWA к этой точке (см. 00-architecture.md).
model PointDevice {
  id      String @id @default(cuid())
  pointId String
  point   Point  @relation(fields: [pointId], references: [id], onDelete: Cascade)

  label     String? // например, "Планшет у входа" — редактируется Владельцем
  activated Boolean @default(false)

  // Устройство не привязано намертво к одной точке — оператор может сменить
  // точку прямо в PWA (POST /api/operator/switch-point), не запрашивая новую
  // ссылку активации у владельца. Обычные "киоск"-устройства (по умолчанию)
  // остаются жёстко привязанными к pointId, заданному при создании.
  roaming Boolean @default(false)

  // Хеш одноразового токена установочной ссылки/QR (до активации) и срок его действия.
  installTokenHash      String?   @unique
  installTokenExpiresAt DateTime?
  activatedAt           DateTime?

  // PIN оператора вводится без выбора имени, поэтому при неверном PIN невозможно
  // понять, чей счётчик попыток увеличивать — блокировка ведётся на уровне
  // устройства точки целиком, а не конкретного оператора.
  failedPinAttempts Int       @default(0)
  pinLockedUntil    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Zone {
  id      String @id @default(cuid())
  pointId String
  point   Point  @relation(fields: [pointId], references: [id], onDelete: Cascade)

  name    String
  iconKey String? // ключ иконки lucide

  // Эмодзи для заголовка Telegram-сводки этой зоны (фидбек пользователя
  // 2026-07-12: "выбор emodji для сводки в телеграм") — отдельно от iconKey
  // (SVG-иконка в UI владельца): Telegram не умеет отрисовать произвольный
  // SVG инлайн, а Unicode-эмодзи — единственный способ дать зоне
  // узнаваемый значок прямо в тексте сообщения. null — telegram-format.ts
  // подставляет 🏁 по умолчанию.
  telegramEmoji String?

  // Временная деактивация (докс: пользовательский фидбек 2026-07-09) — зона
  // на техобслуживании/сезонно не работает. Оператор не видит её в мастере
  // сдачи итогов (см. /api/operator/submission-context), и она не входит в
  // ожидание "все зоны отчитались" для событийной сводки "Касса за день"
  // (см. src/lib/summary-channels/daily-cash-trigger.ts).
  active Boolean @default(true)

  // Режим учёта (docs/spec/01-counters.md) — открытый список, как MoneyOperation.type:
  // "counters" (по счётчикам, накопительные показания активов, по умолчанию) |
  // "launches" (пуски — активы остаются, но вводится готовое число заездов за
  // сдачу, без непрерывного показания) | "cash_only" (только касса — без
  // тарифов/активов, сдаётся только сумма) | "stays" (Прибывания — старт/стоп
  // в реальном времени, см. Launch/LaunchPricing ниже; docs/spec/04-game-room.md).
  // "stays" — самостоятельный режим, РЯДОПОЛОЖНЫЙ остальным, не суб-вариант
  // "launches" (решение пользователя 2026-07-17, было пересмотрено с прежнего
  // "суб-режим Пусков" решения 2026-07-16). Меняется только пока у зоны нет
  // ни одной сдачи итогов — иначе более поздние сдачи молча посчитают
  // показания не в том смысле, что был задуман изначально.
  accountingMode String @default("counters")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tariffs             Tariff[]
  assets              Asset[]
  operatorsWithAccess Operator[]          @relation("OperatorAllowedZones")
  zoneSubmissions     ZoneSubmission[]
  moneyOps            MoneyOperation[]
  landingContent      LandingZoneContent?
  launches            Launch[]
}

// 1 или 2 тарифа на зону: свободное название + цена за сеанс. Те же правила
// и тот же лимит действуют и у режима "Прибывания" (запрос пользователя
// 2026-07-17: "здесь действуют те правила и лимит тарифов") — создаются
// независимо от активов через обычную карточку "Тарифы"/"Добавить тариф",
// просто с доп. полями pricingMode/durationMinutes/roundingMode/minAmount,
// значимыми только когда зона в режиме "stays" (докс: "переиспользовать
// существующую сущность Tariff" вместо отдельной LaunchPricing, а до этого —
// вместо привязки тарифа к конкретному активу через Tariff.assetId, тоже
// пересмотрено). Актив ВЫБИРАЕТ один из тарифов зоны через Asset.tariffId
// (см. ниже) — несколько активов могут ссылаться на один и тот же тариф.
model Tariff {
  id     String @id @default(cuid())
  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  name  String
  // Цена counters/launches и цена/минуту "По факту". У "За вход"
  // (pricingMode="fixed") не используется — там несколько вариантов
  // длительность+цена лежат в options ниже (запрос пользователя 2026-07-17:
  // "1 час, 2 часа..." — выбор оператора при старте, не одна пара), поле
  // остаётся 0 как незначащий placeholder (NOT NULL нужен другим режимам).
  price Decimal @db.Decimal(10, 2)
  // Порядковый номер тарифа в зоне (1 или 2) — определяет, какой из двух
  // счётчиков актива ему соответствует (counters) либо просто порядок в
  // списке (stays).
  order Int

  // Только у зон accountingMode="stays": "fixed" ("За вход" в UI) |
  // "per_minute" ("По факту" в UI). null у обычных тарифов counters/launches.
  pricingMode  String?
  // Только "per_minute"/"По факту" — всегда "up" (докс), выбора у владельца нет.
  roundingMode String?
  // Только "per_minute"/"По факту", обязательное поле.
  minAmount    Decimal? @db.Decimal(10, 2)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Soft-delete (docs/spec/01-counters.md): удаление тарифа не должно ломать
  // Отчёты по прошлым сдачам — AssetReading.tariffId ссылается на этот тариф
  // (без onDelete: Cascade/SetNull), поэтому строка остаётся в БД, просто
  // помечается deletedAt и скрывается из владельческого UI/визарда оператора/
  // лимита "до 2 тарифов". Отчёты (src/lib/reports.ts и др.) читают тарифы
  // БЕЗ фильтра по deletedAt — им нужны и удалённые, чтобы посчитать выручку
  // прошлых периодов.
  deletedAt DateTime?

  assetReadings         AssetReading[]
  initialReadings       AssetInitialReading[]
  // Только accountingMode="launches" — пуски, для которых оператор выбрал
  // этот тариф в реальном времени (Launch.tariffId, запрос пользователя
  // 2026-07-17). Пусто у counters (там тариф — просто цена показания, без
  // ссылки на пуск) и у stays (там своя схема снапшота цены).
  launches              Launch[]
  // Активы режима "Прибывания", которые сейчас используют этот тариф
  // (Asset.tariffId) — необязательная обратная связь, тариф существует
  // независимо от того, привязан ли к нему уже хоть один актив.
  assetsUsingTariff     Asset[]                @relation("AssetTariff")
  // Только "fixed"/"За вход" — варианты длительность+цена (запрос
  // пользователя 2026-07-17: "1 час, 2 часа..." — оператор выбирает при
  // старте пуска, см. TariffOption ниже). Пусто у "per_minute" и обычных
  // тарифов counters/launches.
  options               TariffOption[]
  abonementTransactions AbonementTransaction[]

  // Не @@unique — уникальность (zoneId, order) нужна только среди активных
  // тарифов (иначе освободившийся после soft-delete слот нельзя было бы
  // переиспользовать, см. миграцию 20260711184123_tariff_order_partial_unique).
  @@index([zoneId, order])
}

// Вариант "За вход" (docs/spec/04-game-room.md) — фиксированная цена за
// конкретную длительность, несколько на один Tariff (запрос пользователя
// 2026-07-17: "10 руб. за 1 час, 20 руб. за 2 часа" — родитель/оператор
// выбирает вариант при старте пуска, не одна пара цена/длительность на
// тариф). Простое редактирование на месте — тот же принцип, что у самого
// Tariff в этом режиме (без истории): уже идущий пуск снапшотит выбранный
// вариант на Launch в момент старта, не читает TariffOption заново.
model TariffOption {
  id       String @id @default(cuid())
  tariffId String
  tariff   Tariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)

  durationMinutes Int
  price           Decimal @db.Decimal(10, 2)
  // Порядок отображения списка вариантов в UI — задаёт владелец (порядок
  // добавления по умолчанию).
  order           Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tariffId, order])
}

// ============================================================================
// АБОНЕМЕНТЫ (докс появится позже) — внутренний "кошелёк" клиента,
// пополняемый с бонусом (владелец создаёт пакеты "заплатить X → зачислить
// Y", запрос пользователя 2026-07-17), доступный как способ оплаты пуска на
// "Прибываниях"/"Пусках" наравне с наличными/безналом. Идентификатор —
// номер телефона, баланс ОБЩИЙ на весь тенант (не привязан к точке —
// решение пользователя того же дня: "один номер работает на любой точке
// компании"). Уйти в минус нельзя — списание блокируется на недостающую
// сумму, тот же принцип, что и лимиты подписки.
// ============================================================================

// Абонемент — тариф-план, создаёт владелец (до N штук) — "заплатить price →
// зачислить creditAmount", разница является маркетинговым бонусом, не
// настоящими деньгами (см. AbonementTransaction ниже про раздельный учёт
// кассы/выручки). БЕЗ привязки к конкретному клиенту — план переиспользуется
// любым числом разных кошельков (AbonementWallet ниже). Переименовано из
// AbonementPackage (запрос пользователя 2026-07-17: владелец воспринимает
// именно ЭТО как "абонемент" — план/тариф, а не кошелёк с балансом). Без
// привязки к точкам (запрос пользователя 2026-07-18: "Веди абонемент просто
// зачисляется клиенту" — план всегда виден и продаваем на всех точках
// тенанта; точка нужна только в момент самой оплаты — куда пришли деньги, см.
// AbonementTransaction.pointId — а не как атрибут плана).
model Abonement {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name         String?
  price        Decimal @db.Decimal(10, 2)
  creditAmount Decimal @db.Decimal(10, 2)
  order        Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Soft-delete (тот же принцип, что Tariff) — прошлые AbonementTransaction
  // должны продолжать ссылаться на абонемент, которым когда-то пополнили.
  deletedAt DateTime?

  transactions    AbonementTransaction[]
  moneyOperations MoneyOperation[]

  @@index([tenantId])
}

// Кошелёк клиента — появляется ТОЛЬКО как побочный эффект покупки
// какого-то Abonement (плана), оператором прямо в момент первой оплаты
// (запрос пользователя 2026-07-17: "оператор, прямо в момент оплаты") —
// вводит телефон, выбирает абонемент, кошелёк и первая транзакция создаются
// атомарно. Владелец НЕ создаёт/редактирует кошельки вручную (нет
// бухгалтерской логики за произвольным числом баланса — запрос пользователя
// того же дня); переименовано из Abonement, чтобы имя "Абонемент" осталось
// за планом (см. выше), а не за этой сущностью.
model AbonementWallet {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  phone String
  // Необязательное имя — для будущего поиска по имени (запрос пользователя
  // 2026-07-17: "это потом"), пока просто отображается рядом с телефоном.
  name  String?

  balance Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions AbonementTransaction[]
  launches     Launch[]
  goodsSales   GoodsSale[]

  // Один кошелёк на номер в рамках тенанта — общий на все точки.
  @@unique([tenantId, phone])
  @@index([tenantId])
}

// Журнал операций кошелька — и пополнение, и списание, раздельно от
// MoneyOperation (которая фиксирует денежный СЛЕД операции — кассу точки при
// пополнении, выручку зоны при списании, см. src/lib/abonement.ts), эта
// таблица про сам БАЛАНС кошелька: история для клиента/оператора и опора
// для будущего "поиска по имени".
model AbonementTransaction {
  id       String          @id @default(cuid())
  walletId String
  wallet   AbonementWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // "topup" | "spend" — сумма всегда положительная, знак определяется type.
  type   String
  amount Decimal @db.Decimal(10, 2)

  // Только "topup" — каким абонементом (планом) и как оплатили пополнение
  // (наличные/безнал — те же значения, что у Launch.paymentMethod).
  abonementId   String?
  abonement     Abonement? @relation(fields: [abonementId], references: [id], onDelete: SetNull)
  paymentMethod String?

  // Только "spend" — какой пуск оплачен списанием с баланса.
  launchId String?
  launch   Launch? @relation(fields: [launchId], references: [id], onDelete: SetNull)

  // Только "spend" (оплата товара балансом) / "refund" (сторно аннулированной
  // продажи) — какая продажа (docs/spec/09-goods.md, модуль "Товары"). Тот же
  // приём, что launchId выше.
  goodsSaleId String?
  goodsSale   GoodsSale? @relation(fields: [goodsSaleId], references: [id], onDelete: SetNull)

  // Только "spend" — оплата поездки балансом на активе режима "Счётчики"
  // (docs/spec/01-counters.md). У этого режима нет своей отдельной записи на
  // сеанс (в отличие от Launch у launches/stays) — счётчик тикает физически,
  // по прикосновению RFID-метки, программа об этом не знает вообще; эта
  // запись — независимая ручная фиксация Сотрудником "эта поездка оплачена
  // балансом", не связанная с самим тиком счётчика. tariffId — какой из двух
  // тарифов актива (тот же смысл, что у AssetReading.tariffId).
  assetId  String?
  asset    Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  tariffId String?
  tariff   Tariff? @relation(fields: [tariffId], references: [id], onDelete: SetNull)

  pointId    String?
  point      Point?    @relation(fields: [pointId], references: [id])
  // "Кто провёл" операцию — оператор ИЛИ владелец (тот же приём, что
  // MoneyOperation.performedByUserId/performedByOperatorId), ровно одно из
  // двух заполнено. Владелец получил возможность продавать/пополнять
  // абонементы прямо из кабинета (запрос пользователя 2026-07-17: "это
  // может делать как Владелец, так и Сотрудник") — до этого поля тут не
  // было, топ-ап был возможен только от лица оператора.
  operatorId String?
  operator   Operator? @relation(fields: [operatorId], references: [id])
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([walletId, occurredAt])
  @@index([launchId])
  @@index([goodsSaleId])
  @@index([assetId])
}

// ============================================================================
// ТОВАРЫ (см. docs/spec/09-goods.md) — продажа сопутствующих товаров и
// товаров-услуг на точках. Не встроена в ResultsSubmission/ZoneSubmission
// (решение при проектировании 2026-07-19: Товары продаются на уровне точки,
// не зоны, и не имеют естественного места в зоно-центричном мастере "Сдача
// итогов") — своя независимая сверка кассы, см. GoodsReconciliation ниже.
// Никакого per-tenant feature-флага — противоречило бы 00-architecture.md
// ("никакого per-tenant отключения областей нет и не будет"), единственный
// гейт — операторский тумблер (Operator, поле ниже).
// ============================================================================

model GoodsCategory {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name  String
  order Int    @default(0)

  // Soft-delete — тот же принцип, что у Goods ниже: у архивной категории
  // могут быть товары в истории продаж, ссылку рвать нельзя.
  deletedAt DateTime?

  goods     Goods[]
  revisions GoodsRevision[]

  @@index([tenantId])
}

model Goods {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId String
  category   GoodsCategory @relation(fields: [categoryId], references: [id])

  name     String
  photoUrl String?
  price    Decimal @db.Decimal(10, 2)

  lowStockThreshold Int?
  // Товары-услуги (например, "Комплект для мастер-класса") остаток не
  // ведут — trackStock=false, GoodsStock для них не создаётся вовсе.
  trackStock        Boolean @default(true)

  sortOrder Int       @default(0)
  // Soft-delete (паттерн Tariff/Abonement) — прошлые GoodsSale/GoodsStock
  // должны продолжать ссылаться на товар, которым когда-то торговали.
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  stock         GoodsStock[]
  sales         GoodsSale[]
  restocks      GoodsRestock[]
  revisionLines GoodsRevisionLine[]

  @@index([tenantId])
  @@index([categoryId])
}

// Остаток товара на конкретной точке — создаётся лениво (первое пополнение
// или первая продажа), только для trackStock=true.
model GoodsStock {
  id      String @id @default(cuid())
  goodsId String
  goods   Goods  @relation(fields: [goodsId], references: [id])
  pointId String
  point   Point  @relation(fields: [pointId], references: [id], onDelete: Cascade)

  quantity Int @default(0)

  @@unique([goodsId, pointId])
  @@index([pointId])
}

model GoodsRestock {
  id      String @id @default(cuid())
  goodsId String
  goods   Goods  @relation(fields: [goodsId], references: [id])
  pointId String
  point   Point  @relation(fields: [pointId], references: [id], onDelete: Cascade)

  quantity          Int
  // Пополнение — только владелец (docs/spec/09-goods.md), без
  // performedByOperatorId.
  performedByUserId String
  performedByUser   User   @relation(fields: [performedByUserId], references: [id])

  occurredAt DateTime @default(now())

  @@index([goodsId, pointId])
}

model GoodsSale {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  goodsId  String
  goods    Goods  @relation(fields: [goodsId], references: [id])
  pointId  String
  point    Point  @relation(fields: [pointId], references: [id], onDelete: Cascade)

  quantity      Int
  // Снапшот цены на момент продажи (паттерн Launch.priceSnapshot) — смена
  // цены товара не задевает прошлые продажи.
  priceSnapshot Decimal @db.Decimal(10, 2)
  amount        Decimal @db.Decimal(10, 2) // = priceSnapshot * quantity, хранится, не пересчитывается

  paymentMethod String // "cash" | "mobile" | "abonement"
  walletId      String?
  wallet        AbonementWallet? @relation(fields: [walletId], references: [id])

  performedByOperatorId String?
  performedByOperator   Operator? @relation(fields: [performedByOperatorId], references: [id])
  performedByUserId     String?
  performedByUser       User?     @relation(fields: [performedByUserId], references: [id])

  // Аннулирование — только владелец (CorrectionLog, entityType="GoodsSale").
  // Статус — nullable timestamp, тот же паттерн, что Launch.voidedAt, не
  // отдельное поле "status".
  voidedAt DateTime?

  occurredAt DateTime @default(now()) // серверное время
  createdAt  DateTime @default(now())

  abonementTransactions AbonementTransaction[]

  @@index([pointId, occurredAt])
  @@index([goodsId])
  @@index([walletId])
}

model GoodsRevision {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pointId    String
  point      Point         @relation(fields: [pointId], references: [id], onDelete: Cascade)
  categoryId String
  category   GoodsCategory @relation(fields: [categoryId], references: [id])

  performedByOperatorId String?
  performedByOperator   Operator? @relation(fields: [performedByOperatorId], references: [id])
  performedByUserId     String?
  performedByUser       User?     @relation(fields: [performedByUserId], references: [id])

  // Одно нажатие "Сохранить" в bottom sheet ревизии может затронуть
  // несколько категорий (запрос пользователя 2026-07-19) — каждая всё равно
  // отдельная запись (архитектура категория=ревизия не меняется), но все
  // созданные в одном коммите делят batchId — так История ревизий может
  // группировать их в одну плашку вместо одной на категорию. NULL у записей
  // до этого поля (не группируются, что и раньше).
  batchId String?

  occurredAt DateTime @default(now())

  lines GoodsRevisionLine[]

  @@index([pointId, occurredAt])
  @@index([batchId])
}

model GoodsRevisionLine {
  id         String        @id @default(cuid())
  revisionId String
  revision   GoodsRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  goodsId    String
  goods      Goods         @relation(fields: [goodsId], references: [id])

  // Снапшот GoodsStock.quantity ДО выравнивания — сам GoodsStock тут же
  // перезаписывается на actualQuantity, поэтому "расчётное" нужно хранить
  // явно, иначе история расхождений потеряется безвозвратно.
  calculatedQuantity Int
  actualQuantity     Int

  @@index([revisionId])
}

// Сверка кассы Товаров — НЕ привязана к ResultsSubmission (docs/spec/09-goods.md,
// "Сверка кассы"). Хранит только введённое человеком; расчётная выручка и
// разница всегда считаются на лету суммированием GoodsSale за период
// [предыдущая сверка этой точки → эта] — тот же принцип, что у ZoneSubmission
// (там calculatedRevenue тоже не хранится, а не как у GoodsRevisionLine выше,
// где хранить обязательно — GoodsStock.quantity изменяемый и перезаписывается,
// GoodsSale неизменяем и всегда пересчитываем).
model GoodsReconciliation {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pointId  String
  point    Point  @relation(fields: [pointId], references: [id], onDelete: Cascade)

  performedByOperatorId String?
  performedByOperator   Operator? @relation(fields: [performedByOperatorId], references: [id])
  performedByUserId     String?
  performedByUser       User?     @relation(fields: [performedByUserId], references: [id])

  actualCash   Decimal @db.Decimal(10, 2)
  actualMobile Decimal @db.Decimal(10, 2)

  occurredAt DateTime @default(now())

  @@index([pointId, occurredAt])
}

model Asset {
  id     String @id @default(cuid())
  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  name     String
  photoUrl String? // относительный путь в /uploads/<tenantId>/... (см. src/lib/uploads.ts)
  iconKey  String? // ключ иконки lucide — запасной вариант, когда нет фото
  colorTag String // hex или ключ цвета — обязательный элемент карточки

  // Ручной порядок внутри зоны (кнопки вверх/вниз в карточке зоны) — задаёт
  // владелец, влияет на порядок везде: список активов, форма сдачи итогов,
  // отчёты, сводки (фидбек пользователя 2026-07-11).
  sortOrder Int @default(0)

  // Временная деактивация (запрос пользователя 2026-07-16: конкретный актив
  // на ремонте) — в отличие от Zone.active, оператор ПРОДОЛЖАЕТ видеть
  // деактивированный актив в мастере сдачи итогов (не скрывается), но не
  // может ввести новое показание — поле показания становится read-only с
  // последним известным значением (см. /api/operator/submission-context,
  // src/app/(app)/operator/submit/page.tsx).
  active Boolean @default(true)

  // Только у активов зон accountingMode="stays" — какой тариф зоны
  // использует этот актив (запрос пользователя 2026-07-17: тарифы и активы
  // создаются независимо, владелец потом сам привязывает один к другому;
  // можно оставить пустым, если тариф ещё не создан — привяжет позже).
  // Несколько активов могут указывать на один и тот же тариф.
  tariffId String?
  tariff   Tariff? @relation("AssetTariff", fields: [tariffId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  readings              AssetReading[]
  initialReadings       AssetInitialReading[]
  launches              Launch[]
  abonementTransactions AbonementTransaction[]
}

// Калибровочное показание счётчика (запрос пользователя 2026-07-14: "начинаю
// реальный тест, нужно установить начальные значения") — актив заводится в
// приложение, когда реальный счётчик уже не на нуле (бывший в использовании
// аттракцион). Отдельно от AssetReading намеренно: AssetReading обязательно
// принадлежит ZoneSubmission (реальной сдаче итогов с выручкой) — если бы
// стартовое значение завели через обычную сдачу, "предыдущее показание"
// по умолчанию 0 превратило бы весь стартовый пробег счётчика в фиктивную
// выручку одной сдачи. Используется ТОЛЬКО как fallback там, где ещё нет ни
// одной настоящей AssetReading для этой пары актив+тариф (submission-context,
// submit-results, reports.ts — все три места, где считается "предыдущее
// показание", см. src/lib/asset-initial-readings.ts); как только появляется
// первая реальная сдача, эта запись больше не участвует в расчёте.
model AssetInitialReading {
  id       String @id @default(cuid())
  assetId  String
  asset    Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tariffId String
  tariff   Tariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)

  reading Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assetId, tariffId])
}

// ============================================================================
// СДАЧА ИТОГОВ (не "смена" — см. терминологию в CLAUDE.md)
// ============================================================================

// Один "мастер" сдачи итогов — может быть несколько в день (пересменка).
model ResultsSubmission {
  id       String @id @default(cuid())
  tenantId String
  pointId  String
  point    Point  @relation(fields: [pointId], references: [id], onDelete: Cascade)

  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])

  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  zoneSubmissions ZoneSubmission[]

  // Отчёты (calendar/day, docs/spec/01-counters.md) сканируют по точке и
  // диапазону дат за месяц/день — без индекса это full scan таблицы.
  @@index([pointId, submittedAt])
}

// Данные по одной работавшей зоне внутри одной сдачи итогов.
// Невыбранная зона = не работала, отдельной записи не создаётся.
model ZoneSubmission {
  id                  String            @id @default(cuid())
  resultsSubmissionId String
  resultsSubmission   ResultsSubmission @relation(fields: [resultsSubmissionId], references: [id], onDelete: Cascade)

  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  returnsCount Int // возвраты/тестовые пуски, шт.
  cashAmount   Decimal @db.Decimal(10, 2)
  mobileAmount Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  assetReadings AssetReading[]
  expenses      ExpenseEntry[]
  // Пуски режима "Прибывания", вошедшие в агрегат этой сдачи (docs/spec/
  // 04-game-room.md) — заполняется только у зон accountingMode="stays".
  launches      Launch[]
}

// Показание одного актива по одному тарифу в рамках сдачи итогов зоны.
model AssetReading {
  id               String         @id @default(cuid())
  zoneSubmissionId String
  zoneSubmission   ZoneSubmission @relation(fields: [zoneSubmissionId], references: [id], onDelete: Cascade)

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  tariffId String
  tariff   Tariff @relation(fields: [tariffId], references: [id])

  // Показание счётчика, 4 разряда (0-9999); переполнение и расчёт разницы
  // по модулю 10000 — на уровне приложения, не в БД.
  reading Int

  createdAt DateTime @default(now())

  @@unique([zoneSubmissionId, assetId, tariffId])
  // "Предыдущее показание"/"это последняя сдача в цепочке" (src/lib/results-calc.ts,
  // src/lib/results-submission.ts) всегда ищутся по этой паре с сортировкой по
  // времени — самый горячий путь чтения в модуле Счётчики.
  @@index([assetId, tariffId, createdAt])
}

// Категории расходов (запрос пользователя 2026-07-14) — Владелец сам
// заводит/переименовывает/удаляет; удаление не трогает уже сделанные записи
// расхода (categoryId просто становится null, "без категории") — категория
// это ярлык для отчётности, а не часть финансового расчёта, поэтому soft-delete
// как у Tariff здесь избыточен.
model ExpenseCategory {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())

  expenseEntries ExpenseEntry[]

  @@index([tenantId])
}

model ExpenseEntry {
  id               String         @id @default(cuid())
  zoneSubmissionId String
  zoneSubmission   ZoneSubmission @relation(fields: [zoneSubmissionId], references: [id], onDelete: Cascade)

  categoryId String?
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  amount  Decimal @db.Decimal(10, 2)
  comment String?

  createdAt DateTime @default(now())

  @@index([categoryId])
}

// Правки записей — только владелец. Журнал: кто, когда, было → стало.
// entityType/entityId — свободная ссылка на исправляемую запись (например,
// "AssetReading" + id), чтобы не плодить отдельную таблицу правок на каждую сущность.
model CorrectionLog {
  id         String @id @default(cuid())
  entityType String
  entityId   String

  correctedByUserId String
  correctedBy       User   @relation(fields: [correctedByUserId], references: [id])

  beforeJson Json
  afterJson  Json
  comment    String?

  correctedAt DateTime @default(now())
}

// ============================================================================
// ПРИБЫВАНИЯ (см. docs/spec/04-game-room.md) — Zone.accountingMode="stays",
// самостоятельный режим учёта (не суб-вариант "launches" — пересмотрено
// 2026-07-17, было суб-режимом Пусков до этого). Тариф — Tariff с assetId
// (запрос пользователя 2026-07-17: "переиспользовать существующую сущность
// Tariff" вместо отдельной модели LaunchPricing, которая была здесь раньше)
// с двумя видами ("За вход"/"По факту", см. Tariff.pricingMode), без
// истории — стоимость уже идущего пуска фиксируется снапшотом на Launch в
// момент старта (Launch.*Snapshot ниже), поэтому история цены источника не
// нужна для корректности расчёта.
// ============================================================================

// Один пуск — от старта до стопа, источник времени сервер (тот же паттерн,
// что Shift открытой авто-смены, 05-work-time.md): startedAt/endedAt ставит
// сервер, клиент только отображает отсчёт от startedAt.
model Launch {
  id     String @id @default(cuid())
  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  // Тариф — свойство актива, поэтому пуск без актива невозможен на уровне
  // приложения (сервер отклоняет старт без assetId); поле осталось nullable
  // в БД по историческим причинам, не как разрешённый кейс.
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id])

  // Только у accountingMode="launches" ("Пуски", запрос пользователя
  // 2026-07-17: "тапали по активам и пуски учитывались" — замена бумажной
  // тетрадки с плюсиками цифровым тапом) — какой из ДО ДВУХ тарифов зоны
  // выбрал оператор для этого конкретного пуска (в этом режиме тариф не
  // привязан к активу заранее, как у "Прибываний" через Asset.tariffId —
  // один и тот же актив может держать пуски по обоим тарифам зоны, как
  // сейчас показания по обоим тарифам на один актив в counters/launches).
  // null у "stays" — там цена приходит через priceSnapshot напрямую
  // (TariffOption) или фикс. тариф актива, свой Tariff не нужен на пуске.
  tariffId String?
  tariff   Tariff? @relation(fields: [tariffId], references: [id], onDelete: SetNull)

  // Автонумерация в рамках (zoneId, assetId) — присваивается сервером
  // атомарно (см. docs/spec/04-game-room.md, "Пуск"): два одновременных
  // старта с разных устройств не должны получить один номер.
  number Int

  // Опциональная короткая метка при старте (номер браслета и т.п.) —
  // пользовательский ввод, не переводится (00-architecture.md, "Мультиязычность").
  label String?

  startedAt DateTime  @default(now())
  endedAt   DateTime? // null = ещё открыт

  // Денормализованное зеркало endedAt===null — тот же приём и та же причина,
  // что Shift.isOpen (nullable DateTime фильтр ломается в Prisma Client
  // 7.8.0 + adapter-pg), синхронизируется тем же кодом, что пишет endedAt.
  isOpen Boolean @default(true)

  // Аннулирование — только владелец (docs/spec/04-game-room.md,
  // "Жизненный цикл"); аннулированный пуск исключается из агрегата выручки
  // целиком. Кто/когда/почему — как везде, через CorrectionLog
  // (entityType="Launch"), не отдельными полями здесь.
  voidedAt DateTime?

  // Снапшот тарифа на момент СТАРТА (не FK на LaunchPricing — цена не должна
  // задним числом меняться, если владелец поменял тариф зоны, пока пуск шёл).
  pricingMode             String
  priceSnapshot           Decimal  @db.Decimal(10, 2)
  durationMinutesSnapshot Int?
  roundingModeSnapshot    String?
  minAmountSnapshot       Decimal? @db.Decimal(10, 2)

  // Итоговая стоимость — считается один раз при закрытии и сохраняется (тот
  // же принцип, что AssetReading фиксирует показание раз и навсегда), не
  // пересчитывается на каждое чтение. null, пока пуск открыт.
  amount Decimal? @db.Decimal(10, 2)

  // Способ оплаты — только у "per_minute"/"По факту" (запрос пользователя
  // 2026-07-17: "это только касается тарифа По факту"), спрашивается у
  // оператора при остановке. "cash"/"mobile"/"abonement" — те же значения,
  // что ZoneSubmission.cashAmount/mobileAmount (плюс абонемент). Только
  // СПРАВОЧНАЯ разбивка расчётной выручки (aggregateGameRoomLaunches) — НЕ
  // подставляется автоматически в поля кассы шага 4 мастера сдачи итогов: та
  // сверка физического пересчёта с расчётом ловит недостачи, и подстановка
  // стёрла бы этот контроль для пусков "По факту" (решение пользователя того
  // же дня). null у "fixed"/"За вход" и у пусков, которые ещё не остановлены.
  paymentMethod String?

  // Только paymentMethod="abonement" — какой кошелёк списан (запрос
  // пользователя 2026-07-17). Списание и MoneyOperation "revenue_abonement"
  // создаются сразу при выборе способа оплаты, не откладываются до сдачи
  // итогов — см. src/lib/abonement.ts.
  abonementWalletId String?
  abonementWallet   AbonementWallet? @relation(fields: [abonementWalletId], references: [id], onDelete: SetNull)

  startedByOperatorId String?
  startedByOperator   Operator? @relation("LaunchStartedBy", fields: [startedByOperatorId], references: [id])
  endedByOperatorId   String?
  endedByOperator     Operator? @relation("LaunchEndedBy", fields: [endedByOperatorId], references: [id])

  // Заполняется, когда пуск попал в агрегат конкретной сдачи итогов (по
  // времени стопа) — свободная ссылка без формального @relation, тот же
  // приём, что MoneyOperation.resultsSubmissionId.
  zoneSubmissionId String?
  zoneSubmission   ZoneSubmission? @relation(fields: [zoneSubmissionId], references: [id])

  abonementTransactions AbonementTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // "Сейчас на точке" и восстановление таймеров после перезапуска PWA —
  // горячий путь чтения открытых пусков зоны.
  @@index([zoneId, isOpen])
  // Автонумерация в рамках актива/зоны — MAX(number) по этой паре.
  @@index([zoneId, assetId, number])
  // Агрегат для сдачи итогов — завершённые пуски зоны за период.
  @@index([zoneId, endedAt])
  @@index([zoneSubmissionId])
}

// ============================================================================
// ДЕНЬГИ (см. 02-money.md)
// ============================================================================

// Тип операции — свободная строка (список расширяемый, будущие модули
// добавляют свои типы). На сегодня: revenue / expense / collection / change_fund
// (касса зоны) и advance / bonus_payout (касса точки, см. 05-work-time.md).
model MoneyOperation {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // РОВНО ОДНО из двух заполнено (CHECK-констрейнт в миграции) — какая касса
  // меняется. zoneId — обычные операции Счётчиков/Денег. pointId — операции
  // Рабочего времени: касса точки в целом, не привязанная к конкретной зоне.
  zoneId String?
  zone   Zone?   @relation(fields: [zoneId], references: [id])

  pointId String?
  point   Point?  @relation(fields: [pointId], references: [id])

  // Только abonement_topup/abonement_topup_cashless — какой план продан
  // (запрос пользователя 2026-07-18: реальные деньги за конкретный план,
  // без пересчёта по ТЕКУЩЕЙ цене плана — та могла с тех пор измениться,
  // из-за чего сумма по плану и реальная сумма расходились).
  abonementId String?
  abonement   Abonement? @relation(fields: [abonementId], references: [id], onDelete: SetNull)

  type   String
  amount Decimal @db.Decimal(10, 2)

  // "Кто провёл" операцию (ввёл/отредактировал).
  performedByUserId     String?
  performedByUser       User?     @relation(fields: [performedByUserId], references: [id])
  performedByOperatorId String?
  performedByOperator   Operator? @relation(fields: [performedByOperatorId], references: [id])

  // "Получатель" — чей баланс меняет операция (только advance/bonus_payout).
  // Отдельно от performedBy*: владелец может провести операцию за оператора.
  beneficiaryOperatorId String?
  beneficiaryOperator   Operator? @relation("MoneyOperationBeneficiary", fields: [beneficiaryOperatorId], references: [id])

  comment String?

  // Ссылка на сдачу итогов, если операция создана автоматически ею (revenue/expense).
  resultsSubmissionId String?

  // Ссылка на смену, если аванс/премия введены прямо в форме смены (тот же
  // свободный приём без формального @relation, что у resultsSubmissionId).
  shiftId String?

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  // Отчёт «Деньги» сканирует весь журнал тенанта; правка/удаление сдачи
  // (src/app/api/reports/counters/zone-submission/[id]) ищет операцию по
  // конкретной сдаче+зоне.
  @@index([tenantId])
  @@index([resultsSubmissionId, zoneId])
  // Расчёт баланса оператора ("к выдаче"/"заработано за период") сканирует
  // все advance/bonus_payout конкретного получателя — горячий путь карточки
  // оператора и вкладки "Время" в PWA.
  @@index([beneficiaryOperatorId, type, occurredAt])
  @@index([pointId])
  @@index([shiftId])
}

// ============================================================================
// РАБОЧЕЕ ВРЕМЯ (см. 05-work-time.md)
// ============================================================================

// История ставок оператора. Действующая ставка на дату X = запись с
// максимальным effectiveFrom <= X. Смена ставки не пересчитывает прошлые
// смены ("СТАВКА" в 05-work-time.md) — Shift ищет свою дату в этой истории
// при каждом чтении, ничего не денормализуется.
model OperatorRate {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  rate          Decimal  @db.Decimal(10, 2) // часовая ставка
  effectiveFrom DateTime // действует начиная с этой даты (включительно)

  createdAt DateTime @default(now())

  @@index([operatorId, effectiveFrom])
}

// Смена — только сырые факты (начало/конец). Начислено/минуты/действовавшая
// ставка НЕ хранятся — считаются на чтении (минуты = endAt − startAt, ставка
// = OperatorRate на дату startAt), как AssetReading/сеансы в Счётчиках.
// Аванс/премия по смене — НЕ поля здесь, а отдельные MoneyOperation
// (type=advance|bonus_payout, shiftId=this.id) — единственный источник
// правды про деньги остаётся журнал Денег (см. 02-money.md).
model Shift {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  // Точка, на которой отмечена смена (из сессии устройства при создании
  // оператором — как ResultsSubmission.pointId). Нужна, чтобы знать, из кассы
  // какой точки списывать привязанные к смене advance/bonus_payout — Operator
  // сам по себе не привязан к одной точке (роуминг-устройства).
  pointId String
  point   Point  @relation(fields: [pointId], references: [id])

  // Смена через полночь: endAt физически на следующие сутки после startAt —
  // "дата смены" (для группировки/фильтров) всегда дата startAt.
  startAt DateTime
  // null = смена ещё идёт — только в режиме Operator.timeTrackingMode = "auto"
  // (docs/spec/05-work-time.md, "РЕЖИМ УЧЁТА ВРЕМЕНИ"), между check-in и
  // check-out. В режиме "manual" всегда заполнено сразу при создании. На
  // оператора может быть не больше одной открытой смены — обеспечено
  // частичным уникальным индексом на isOpen в миграции.
  endAt   DateTime?

  // Денормализованное зеркало "endAt === null" — заведено ТОЛЬКО потому, что
  // фильтрация nullable DateTime (endAt: null / {equals:null} / {not:null})
  // ломается в этой версии Prisma Client (7.8.0, генератор "prisma-client" +
  // @prisma/adapter-pg): PrismaClientValidationError на ровном месте, хотя
  // nullable String фильтруется нормально (проверено вручную). isOpen всегда
  // устанавливается синхронно с endAt (создание/check-in → true+null,
  // check-out/правка → false+дата) — держать в актуальном состоянии только
  // тем кодом, что пишет endAt.
  isOpen Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Табель сортирует/фильтрует по оператору и дате — горячий путь.
  @@index([operatorId, startAt])
}

// Перенос баланса — ручная запись владельца (стартовый баланс/корректировка),
// НЕ операция денежного журнала: это не движение физической наличности, а
// корректировка того, сколько компания должна оператору ("БАЛАНС" в
// 05-work-time.md). Хранится отдельно от MoneyOperation по этой же причине.
model OperatorBalanceCarryover {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  amount  Decimal @db.Decimal(10, 2) // может быть отрицательным
  comment String?

  createdByUserId String
  createdByUser   User   @relation(fields: [createdByUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([operatorId])
}

// ============================================================================
// СВОДКИ В КАНАЛЫ (docs/spec/telegram-summaries.md)
// ============================================================================

enum SummaryChannelType {
  telegram
  email
}

// Один платформенный Telegram-бот на всех тенантов (токен — секрет бэкенда,
// в .env, никогда не в этой таблице и не на фронте) — модель отличается от
// email: для Telegram нужен факт привязки конкретного чата через код,
// для email привязки как таковой нет, просто список адресов.
//
// pointId=null — общий чат тенанта (единственный режим, который использует
// сейчас UI); точечные привязки — задел на будущее, см. спеку.
//
// Пересвязка на новый чат не затирает старую запись, а деактивирует её
// (enabled=false, chatStatus=inactive) и создаёт новую — так остаётся
// история "куда раньше уходили сводки", как и везде в проекте (CorrectionLog).
model TenantSummaryChannel {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channelType SummaryChannelType

  pointId String?
  point   Point?  @relation(fields: [pointId], references: [id], onDelete: Cascade)

  // Пользовательский тумблер "вкл/выкл" на экране настроек — независим от
  // chatStatus (это системный факт "бот всё ещё состоит в чате").
  enabled Boolean @default(true)

  // --- Telegram ---
  chatId     String?
  chatTitle  String?
  // active | inactive (бот кикнут/вышел — my_chat_member вебхук).
  chatStatus String?

  // --- Email ---
  // Через запятую, как договорились в Шаге 3.5 (без отдельной таблицы адресов —
  // это не тянет на самостоятельную сущность).
  emailAddresses String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, channelType])
  @@index([chatId])
}

// Одноразовый код привязки Telegram-чата (/start <код> в группе).
// Криптослучайный, не последовательный, TTL 15 минут, гасится после первого
// использования (usedAt) — не удаляется, чтобы не терять аудит-след попыток.
model TelegramBindCode {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code String @unique

  // Задел на точечные привязки — сейчас всегда null (общий чат тенанта).
  pointId String?

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId])
}

// Настройки состава и триггера каждого типа сводки — по одной строке на
// тенанта, лениво создаётся при первом сохранении (как остальные настройки
// тенанта в проекте — locale/accentScheme и т.п. живут прямо на Tenant, но
// здесь полей многовато для этого, отсюда три отдельные модели 1:1, не JSON).
// Дефолты повторяют то, что включено/выключено в прототипе.

model ZoneSummarySettings {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  enabled Boolean @default(true)

  showReadings Boolean @default(true) // Показания по активам
  showDelta    Boolean @default(true) // Заезды (дельта)
  showCash     Boolean @default(true) // Касса по типам оплаты
  showCalc     Boolean @default(true) // Расчёт по счётчику
  showDiff     Boolean @default(true) // Разница
  showReturns  Boolean @default(true) // Возвраты/тестовые
  showOperator Boolean @default(false) // Имя оператора

  // Только Telegram — компактная 2-колоночная таблица показаний (имя актива
  // до 5 символов) вместо списка, чтобы сообщение помещалось по ширине экрана.
  compact Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyCashSummarySettings {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  enabled Boolean @default(true)

  // "event" (когда все смены закроются) | "fixed" (по времени) — см.
  // src/lib/summary-settings.ts, DAILY_CASH_SEND_MODES.
  sendMode  String @default("event")
  fixedTime String @default("23:00") // HH:MM, используется только при sendMode="fixed"

  // businessDayBoundary переехал на Tenant.businessDayBoundary (2026-07-11) —
  // общетенантное значение, читает и этот экран, и Рабочее время.

  skipIfNoSubmissions    Boolean @default(true) // Не отправлять без сдач
  updateOnLateSubmission Boolean @default(true) // Обновлять при досдаче (editMessageText, не новое сообщение)

  showCash          Boolean @default(true) // Касса по типам оплаты
  showExpenses      Boolean @default(true) // Расходы за день
  showZoneBreakdown Boolean @default(false) // Разбивка по зонам
  showCashOnHand    Boolean @default(false) // Остаток наличных на точке

  // Только Telegram — см. ZoneSummarySettings.compact.
  compact Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShiftCloseSummarySettings {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  enabled Boolean @default(true)

  showPeriod  Boolean @default(true)
  showHours   Boolean @default(false)
  showAdvance Boolean @default(true)
  showBonus   Boolean @default(true)
  showTotal   Boolean @default(true) // К выдаче

  // Только Telegram — сводит поля на 2 строки вместо одной строки на каждое.
  compact Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Тумблер уведомления "Прохождение инструктажа" (docs/spec/07-instructions.md,
// доп. решение 2026-07-12) — единственное поле, в отличие от Zone/DailyCash/
// ShiftClose нет настроек состава сообщения (оно и так одна строка): "{Имя}
// ознакомился с инструкцией «{Название}» за {время чтения}". Отдельная
// модель, не поле на Instruction — это тенант-wide переключатель канала
// уведомления, не свойство конкретной инструкции.
model InstructionAckSummarySettings {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Факт отправки "Кассы за день" на точку+бизнес-день+канал — источник
// идемпотентности (не отправить дважды за один тик планировщика) и место для
// externalMessageId, нужного editMessageText при досдаче ("обновлять при
// досдаче" в DailyCashSummarySettings).
model DailyCashSummaryDelivery {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pointId  String
  point    Point  @relation(fields: [pointId], references: [id], onDelete: Cascade)

  // Полночь UTC начала бизнес-дня (не календарная дата) — см. businessDateKey.
  businessDate DateTime

  channelType       SummaryChannelType
  externalMessageId String? // Telegram message_id как строка; для email не используется

  sentAt    DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pointId, businessDate, channelType])
}

// ============================================================================
// ЗАДАЧИ (см. docs/design/prototype-tasks-v1.html) — привязаны к Точке, не к
// тенанту целиком (подтверждено пользователем 2026-07-09): у владельца с
// несколькими точками — своя доска на каждую, оператор видит только доску
// своей точки. Статус — открытая строка (тот же приём, что MoneyOperation.type):
// "todo" | "doing" | "done".
model Task {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pointId  String
  point    Point  @relation(fields: [pointId], references: [id], onDelete: Cascade)

  title  String
  note   String?
  status String  @default("todo")

  createdByUserId String
  createdBy       User   @relation("TaskCreatedBy", fields: [createdByUserId], references: [id])

  // Ответственные — операторы и/или сам Владелец (User); пусто в обоих
  // спискax = "видят все операторы" (см. prototype-tasks-v1.html, opVisible()).
  // Назначение на User — просто пометка "это моё", доска владельца и так
  // показывает все задачи точки независимо от назначения.
  assignedOperators Operator[] @relation("TaskAssignedOperators")
  assignedUsers     User[]     @relation("TaskAssignedUsers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pointId, status])
}

// ============================================================================
// SUPER ADMIN: биллинг (docs/spec/06-super-admin.md)
// ============================================================================

// Сырой лог вебхуков FluentCart — пишется независимо от исхода обработки
// (даже при ошибке/пропуске из-за manualStatusOverride), read-only в UI
// карточки тенанта. Отдельного экрана "лог вебхуков с ресинком" нет
// (см. "вне скоупа" в спеке) — это только для отладки синхронизации.
model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String // "fluentcart"
  eventType  String
  payload    Json
  status     String // "processed" | "failed"
  error      String?
  receivedAt DateTime @default(now())

  // Тенант, к которому удалось привязать событие (по fluentcartCustomerId) —
  // null, если тенант не был найден/создан (см. sync до броска исключения в
  // fluentcart-webhook.ts). Денормализовано ради истории биллинга в карточке
  // тенанта (docs/spec/06-super-admin.md, п.4) — без FK на Tenant, чтобы
  // удаление тенанта не тянуло/не блокировало удаление лога вебхуков.
  tenantId String?

  @@index([tenantId])
}

// Единственная запись (id всегда "singleton") — глобальные настройки
// платформы: токен Telegram-бота, SMTP, дефолтные локаль/таймзона/валюта
// для новых тенантов. Редактируется только в /admin/settings.
model SystemSettings {
  id     String @id @default("singleton")
  config Json
}

// ============================================================================
// ИНСТРУКТАЖИ (docs/spec/07-instructions.md) — автономный модуль, без
// зависимости на Point/Zone/Operator. Без feature-флага (решение пользователя
// 2026-07-12, как остальные модули — см. раздел "Открытые вопросы" в спеке).
// ============================================================================

enum InstructionStatus {
  draft
  published
  archived
}

// Instruction.title/content — ТЕКУЩИЙ РЕДАКТИРУЕМЫЙ черновик владельца, не
// источник правды для публичной страницы. Публичная страница и PDF всегда
// читают из InstructionVersion (immutable snapshot) — правка уже
// опубликованной инструкции не меняет то, что прямо сейчас показывается и
// подписывается, пока владелец не нажмёт "Опубликовать" снова.
model Instruction {
  id           String            @id @default(cuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug         String
  status       InstructionStatus @default(draft)
  // "Проверка честности" — кнопка "Готово" на публичной странице неактивна,
  // пока страница не проскроллена до конца (порог ~95%).
  honestyCheck Boolean           @default(false)

  title   String
  // ProseMirror/Tiptap JSON (не HTML) — схема редактора ограничена набором
  // { doc, paragraph, heading(1|2), text, bold, italic, underline, bulletList,
  // orderedList, listItem } на уровне extensions самого Tiptap и повторно
  // проверяется на сервере при сохранении (см. Шаг 2, обоснование формата).
  // Структурная невозможность вставить произвольный HTML/script — это и есть
  // защита от XSS, не сanitize-фильтр поверх свободного HTML.
  content Json

  // Денормализовано ради дешёвого сравнения "запись устарела?" в журнале
  // (record.version.versionNumber < currentVersionNumber) без лишнего джойна
  // по каждой строке журнала. Источник правды всё равно versions ниже.
  currentVersionNumber Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions     InstructionVersion[]
  records      AcknowledgmentRecord[]
  // Обратная связь для Landing.rulesInstructionId (docs/spec/08-landing.md,
  // "Правила посещения") — опциональная ссылка лендинга на опубликованную
  // инструкцию.
  landingLinks Landing[]

  @@unique([tenantId, slug])
}

// Immutable snapshot — создаётся при каждой публикации (первой или повторной
// после правки уже опубликованной инструкции). Никогда не редактируется и не
// удаляется после создания (кроме каскада при удалении самой Instruction).
model InstructionVersion {
  id            String      @id @default(cuid())
  instructionId String
  instruction   Instruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  versionNumber Int
  // Заголовок и контент на момент этой публикации — заголовок мог
  // измениться в более поздней версии, снимок должен остаться дословным.
  title         String
  content       Json
  publishedAt   DateTime    @default(now())

  records AcknowledgmentRecord[]

  @@unique([instructionId, versionNumber])
}

// Запись ознакомления — снимок введённых человеком данных + метаданные
// подписания. Подписант — всегда внешнее лицо (нет FK на User/Operator, даже
// если по факту это оператор тенанта, см. "Назначение" в спеке).
model AcknowledgmentRecord {
  id            String             @id @default(cuid())
  instructionId String
  instruction   Instruction        @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  versionId     String
  version       InstructionVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  lastName  String
  firstName String
  phone     String
  birthDate DateTime

  // PNG подписи — BLOB в БД, не файл в /uploads (см. Шаг 2, обоснование):
  // маленький размер (штриховой рисунок, не фото), нет собственного
  // публичного URL по спеке ("не показывается в таблице — только в PDF"),
  // атомарное удаление вместе со строкой/в одной транзакции с журналом правок.
  signaturePng Bytes

  // Вспомогательная метрика (спека explicitly: "защищать от манипуляций не
  // нужно") — секунды от открытия страницы до отправки формы, с паузой на
  // visibilitychange.
  readingSeconds Int

  ip           String
  userAgent    String
  // Распарсенные из userAgent при сохранении (ua-parser-js, см. Шаг 2) —
  // денормализовано ради колонок журнала без парсинга на каждый рендер.
  deviceLabel  String?
  browserLabel String?

  createdAt DateTime @default(now())

  // [instructionId, ip, createdAt] — под rate limit на публичном эндпоинте
  // подписания (Шаг 3): считаем недавние попытки с этого IP по этой
  // инструкции без отдельной таблицы.
  @@index([instructionId, createdAt])
  @@index([instructionId, ip, createdAt])
}

// ============================================================================
// ЛЕНДИНГ (docs/spec/08-landing.md) — публичная витрина тенанта на
// /s/{tenant-slug} (был /site/{tenant-slug} до 2026-07-14, старый префикс —
// 301 в next.config.ts redirects()). Без feature-флага, как остальные модули (решение
// пользователя 2026-07-13). Один Landing на тенанта (tenantId @unique).
// Переиспользует Tenant.slug (общий с Инструктажами) и src/lib/uploads.ts
// для всех фото — второй механизм загрузки не заводится.
// ============================================================================

// Старые значения Tenant.slug — под 301. Общая для ОБОИХ публичных роутов,
// резолвящихся по слагу (/i/... Инструктажей и /s/... Лендинга): резолвер
// сначала пробует текущий Tenant.slug, при промахе — эту таблицу, и если
// находит — отдаёт 301 на актуальный slug. Старое значение остаётся здесь
// навсегда, не переиспользуется другим тенантом — иначе кто-то другой может
// "перехватить" уже расклеенные QR-коды/визитки со старым адресом.
model TenantOldSlug {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  slug      String   @unique
  createdAt DateTime @default(now())

  @@index([tenantId])
}

enum LandingStatus {
  draft
  published
}

// docs/spec/08-landing.md, "Темы лендинга" — 6 фиксированных пресетов
// design-токенов поверх единой вёрстки, без отдельных шаблонов на тему.
enum LandingTheme {
  modern
  classic
  retro
  festival
  neon
  pixel
}

// docs/spec/08-landing.md, "Эффекты лендинга" — ровно один активный эффект
// частиц или его отсутствие; "none" — реальное значение по умолчанию, не
// просто null, чтобы форма владельца всегда имела выбранный чип.
enum LandingEffect {
  none
  snow
  confetti
  bubbles
  leaves
  sparks
  petals
  fireworks
}

model Landing {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  status LandingStatus @default(draft)

  // docs/spec/08-landing.md, "Темы лендинга"/"Эффекты лендинга" (2026-07-13).
  theme  LandingTheme  @default(modern)
  effect LandingEffect @default(none)

  // Секретная ссылка превью (докс, "Жизненный цикл") — работает независимо
  // от status, черновик можно показать клиенту до публикации. В открытую
  // (plaintext), НЕ хэш — в отличие от PointDevice.installTokenHash (тот
  // одноразовый, после активации показывать снова не нужно), эта ссылка
  // постоянная и владелец открывает её из кабинета многократно.
  previewToken String @unique @default(cuid())

  // tagline — короткий однострочный слоган, plain text (санитизация только
  // при выводе). aboutText — с 2026-07-13 тот же формат, что Instruction.content
  // (ProseMirror/Tiptap JSON, docs/spec/07-instructions.md, Шаг 2) — решение
  // пользователя: "тот же примитвный редактор, как и в инструкциях" для
  // текста "О нас" (раньше здесь был "БЕЗ rich-редактора" — докс устарел,
  // обновить). Валидация тем же белым списком — src/lib/rich-text.ts.
  tagline   String?
  aboutText Json?

  galleryEnabled  Boolean @default(false)
  ourFleetEnabled Boolean @default(false) // "Наш парк" — сетка активов с фото
  // Цены тарифов на карточках зон (докс: "У нас работают") — отдельный
  // переключатель владельца (решение пользователя 2026-07-13: цены могут
  // отпугивать часть посетителей, дефолт true — сохраняет текущее поведение
  // для уже опубликованных лендингов).
  showPrices      Boolean @default(true)

  // Правила посещения — опциональная ссылка на ОПУБЛИКОВАННУЮ инструкцию.
  // Статус Instruction не проверяется на уровне схемы (Prisma этого не
  // умеет) — валидируется при сохранении и повторно на рендере: если
  // инструкцию сняли с публикации после привязки, блок просто не рендерится
  // (Шаг 3/4), а не 500-ит и не показывает мёртвую ссылку.
  rulesInstructionId String?
  rulesInstruction   Instruction? @relation(fields: [rulesInstructionId], references: [id], onDelete: SetNull)

  contactPhone     String?
  contactTelegram  String?
  contactViber     String?
  contactWhatsapp  String?
  contactInstagram String?
  contactFacebook  String?
  contactTiktok    String?
  contactVk        String? // ВКонтакте (решение пользователя 2026-07-13 — российские соцсети в Контактах)
  contactOk        String? // Одноклассники
  contactYoutube   String? // ссылка на канал (докс, "Секция видео" — добавлено в список соцсетей)

  // docs/spec/08-landing.md, "Секция видео" (2026-07-13). ID видео — уже
  // распарсенный YouTube ID (не сырая ссылка владельца, докс требует парсер
  // на сохранении); videoPoster — обложка, скачанная сервером и сохранённая
  // через тот же механизм, что остальные фото (src/lib/uploads.ts), а не
  // прямая ссылка на img.youtube.com (докс: обложка валидирует существование
  // ролика и на публичной странице отдаётся ТОЛЬКО из нашего хранилища).
  // videoEnabled — отдельный флаг видимости (докс, Шаг 6: "переключатель
  // секции" и "Удалить видео" — два разных элемента управления, значит
  // выключение переключателем не должно стирать videoYoutubeId/videoPoster;
  // тот же паттерн, что galleryEnabled/ourFleetEnabled выше). "Удалить
  // видео" обнуляет все три поля разом.
  videoEnabled   Boolean @default(false)
  videoYoutubeId String?
  videoPoster    String?

  // Переопределение шаблонного title/description (докс, раздел SEO).
  metaTitleOverride       String?
  metaDescriptionOverride String?

  // Код подтверждения владения сайтом для Google Search Console (решение
  // пользователя 2026-07-14, Яндекс.Вебмастер убран 2026-07-16 — не
  // поддерживает верификацию по HTML-тегу для сайта в подпапке, как
  // /s/{slug} на общем домене my.rentos365.app) — рендерится как
  // <meta name="google-site-verification" content="..."> в <head> (Next.js
  // Metadata API, поле verification в buildLandingMetadata,
  // src/lib/landing/metadata.ts). Домен my.rentos365.app тенанту не
  // принадлежит — DNS-верификация недоступна физически, но верификация по
  // HTML-тегу для конкретного URL работает и без владения доменом целиком,
  // тот же паттерн, что у Wix/Squarespace/Shopify. Хранится только САМ КОД
  // (значение content=), не вся строка тега — вставляется в разметку
  // сервером, владелец не пишет HTML напрямую.
  googleSiteVerification String?

  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  galleryPhotos LandingGalleryPhoto[]
  zoneContents  LandingZoneContent[]
  dailyStats    LandingDailyStat[]
}

// Фото галереи (докс: 5–10 шт., drag-and-drop порядок). url — путь вида
// /uploads/<tenantId>/... через src/lib/uploads.ts, тот же механизм, что у
// Asset.photoUrl/Operator.avatarUrl/Tenant.logoUrl — второй не заводится.
model LandingGalleryPhoto {
  id        String  @id @default(cuid())
  landingId String
  landing   Landing @relation(fields: [landingId], references: [id], onDelete: Cascade)

  url       String
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())

  @@index([landingId, sortOrder])
}

// Одна строка на зону, получившую "витринное" фото и/или свою подпись в
// разделе Лендинг (решение 2026-07-13: у Zone нет собственного фото и не
// будет — ни дефолта, ни иконки как замены; без этой записи или с пустым
// photoUrl карточка зоны на публичной странице рендерится без изображения).
// Строка создаётся лениво — не для каждой зоны тенанта сразу, только когда
// владелец что-то заполнил.
model LandingZoneContent {
  id        String  @id @default(cuid())
  landingId String
  landing   Landing @relation(fields: [landingId], references: [id], onDelete: Cascade)
  // @unique, не просто индекс: зона принадлежит ровно одной точке ровно
  // одного тенанта, а Landing — 1:1 с тенантом, значит у зоны не может быть
  // больше одной записи "витринного" контента. Prisma также требует @unique
  // на стороне FK для one-to-one связи Zone.landingContent.
  zoneId    String  @unique
  zone      Zone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  photoUrl String? // /uploads/<tenantId>/... (src/lib/uploads.ts)
  // ProseMirror/Tiptap JSON — тот же примитивный редактор, что у Instruction.content
  // (решение пользователя 2026-07-13), валидация — src/lib/rich-text.ts.
  // null → нет подписи, строка не рендерится (докс, "Правила вёрстки" п.7).
  caption  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([landingId])
}

// Дневные агрегаты статистики (докс: "Статистика посещений" — сырые события
// не хранятся). date — календарный день ПО ТАЙМЗОНЕ ТЕНАНТА (Tenant.timezone,
// тот же принцип, что для business-day boundary в src/lib/business-day.ts),
// не UTC-день — иначе "сегодня" в кабинете разъедется с реальным днём
// посетителя владельца.
model LandingDailyStat {
  id        String  @id @default(cuid())
  landingId String
  landing   Landing @relation(fields: [landingId], references: [id], onDelete: Cascade)

  date DateTime @db.Date

  visits         Int @default(0)
  uniqueVisitors Int @default(0)

  // По реферру (докс: "прямые/поиск/соцсети") — нераспознанный/пустой
  // реферрер учитывается как "прямой", отдельного бакета "прочее" нет,
  // ровно три категории, как в спеке.
  sourceDirect Int @default(0)
  sourceSearch Int @default(0)
  sourceSocial Int @default(0)

  deviceMobile  Int @default(0)
  deviceDesktop Int @default(0)

  // Гео (страна/город) сознательно НЕ собирается (решение пользователя
  // 2026-07-13: "уходим от платных чужих сервисов вообще") — GeoLite2/
  // MaxMind сама по себе бесплатна, но требует стороннего аккаунта и
  // лицензионного ключа, от чего решили полностью отказаться. Было
  // topCountries/topCities Json?, убрано вместе с src/lib/landing/geo.ts.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([landingId, date])
}

// Суточный дедуп-набор анонимных хэшей (hash(IP+UA+соль дня), докс) — НЕ
// "сырые события": здесь нет IP, нет точного времени визита, нет referrer,
// только опознавательный хэш + день, нужен исключительно чтобы посчитать
// uniqueVisitors ровно один раз за день без хранения состояния в памяти
// процесса (несколько инстансов/рестарт не должны давать задвоение). Старые
// дни подлежат периодической очистке (Шаг 3) — после того как день закрыт,
// сам хэш больше не нужен, агрегат уже лежит в LandingDailyStat.
model LandingVisitorSeen {
  id          String   @id @default(cuid())
  landingId   String
  date        DateTime @db.Date
  visitorHash String

  @@unique([landingId, date, visitorHash])
  @@index([date])
}
